{
  "manifest_version": 3,
  "name": "Skip This Job — Ghost Job Detector",
  "version": "0.1.0",
  "description": "Detect ghost job listings on LinkedIn and Indeed. Get ghost risk scores, repost tracking, and employer transparency.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.linkedin.com/feed/*"
      ],
      "js": ["content/linkedin.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.indeed.com/*"
      ],
      "js": ["content/indeed.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
